// lib/helpers/download_helper.dart
// Nécessite dans pubspec.yaml :
//   dio: ^5.4.0
//   path_provider: ^2.1.2
//   permission_handler: ^11.3.0
//   open_filex: ^4.3.4

import 'dart:io';
import 'package:dio/dio.dart';
import 'package:flutter/material.dart';
import 'package:open_filex/open_filex.dart';
import 'package:path_provider/path_provider.dart';
import 'package:permission_handler/permission_handler.dart';

class DownloadHelper {
  static final Dio _dio = Dio();

  // ─── BASE URL — adapte selon ton environnement ───────────────
  static const String baseUrl = 'http://TON_IP:5000'; // ex: http://192.168.1.10:5000

  // ─── Télécharger un fichier depuis /download/:filename ────────
  // [filename]       : nom du fichier ex: "media-1717000000000-123456789.mp4"
  // [onProgress]     : callback optionnel (reçoit 0.0 à 1.0)
  // [openAfter]      : ouvrir le fichier après téléchargement
  static Future<void> downloadFile({
    required BuildContext context,
    required String filename,
    void Function(double progress)? onProgress,
    bool openAfter = false,
  }) async {
    // 1. Demander la permission de stockage (Android)
    if (Platform.isAndroid) {
      final status = await Permission.storage.request();
      if (!status.isGranted) {
        if (context.mounted) {
          ScaffoldMessenger.of(context).showSnackBar(
            const SnackBar(content: Text('Permission de stockage refusée')),
          );
        }
        return;
      }
    }

    // 2. Dossier de destination
    final Directory dir;
    if (Platform.isAndroid) {
      dir = Directory('/storage/emulated/0/Download/Yansnet');
    } else {
      dir = await getApplicationDocumentsDirectory();
    }

    if (!await dir.exists()) {
      await dir.create(recursive: true);
    }

    final String savePath = '${dir.path}/$filename';
    final String downloadUrl = '$baseUrl/download/$filename';

    // 3. Afficher un snackbar de début
    if (context.mounted) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Téléchargement de $filename...'),
          duration: const Duration(seconds: 60),
        ),
      );
    }

    try {
      // 4. Lancer le téléchargement avec progression
      await _dio.download(
        downloadUrl,
        savePath,
        onReceiveProgress: (received, total) {
          if (total > 0 && onProgress != null) {
            onProgress(received / total);
          }
        },
      );

      // 5. Succès
      if (context.mounted) {
        ScaffoldMessenger.of(context).hideCurrentSnackBar();
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Fichier téléchargé : $filename'),
            action: SnackBarAction(
              label: 'Ouvrir',
              onPressed: () => OpenFilex.open(savePath),
            ),
          ),
        );
      }

      // 6. Ouvrir automatiquement si demandé
      if (openAfter) {
        await OpenFilex.open(savePath);
      }
    } on DioException catch (e) {
      if (context.mounted) {
        ScaffoldMessenger.of(context).hideCurrentSnackBar();
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Erreur téléchargement : ${e.message}')),
        );
      }
    }
  }

  // ─── Extraire le nom de fichier depuis une URL complète ────────
  // ex: "http://192.168.1.10:5000/uploads/media-123.mp4" → "media-123.mp4"
  static String filenameFromUrl(String url) {
    return url.split('/').last;
  }

  // ─── Construire l'URL d'affichage (inline) ────────────────────
  static String displayUrl(String filename) {
    return '$baseUrl/uploads/$filename';
  }

  // ─── Construire l'URL de téléchargement forcé ─────────────────
  static String downloadUrl(String filename) {
    return '$baseUrl/download/$filename';
  }
}